PORT=5000
NODE_ENV=production
DATABASE_URL=postgresql://postgres:password@localhost:5432/swahilipot_ims
JWT_SECRET=your_very_long_random_secret_here
CLIENT_URL=http://localhost:5173

# ---- File uploads ----
# STORAGE_DRIVER: "local" (store on the server disk — default) or "s3".
STORAGE_DRIVER=local
# Where local uploads are written (used when STORAGE_DRIVER=local).
UPLOADS_DIR=./uploads

# S3 — REQUIRED ONLY when STORAGE_DRIVER=s3. Leave blank for local storage.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Optional: only set for S3-compatible providers (Cloudflare R2, MinIO, ...)
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# ---- Email (password-reset links) ----
# Optional: if SMTP_HOST is unset, reset links are printed to the server
# console (visible via `pm2 logs sph-api`) instead of being emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SwahiliPot IMS <no-reply@swahilipothub.co.ke>
