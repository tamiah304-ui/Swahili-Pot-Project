PORT=5000
NODE_ENV=production
DATABASE_URL=postgresql://postgres:password@localhost:5432/swahilipot_ims
JWT_SECRET=your_very_long_random_secret_here
CLIENT_URL=http://localhost:5173

# ---- File uploads ----
# Storage is chosen automatically: if the AWS_* + S3_BUCKET values below are
# filled in, uploads go to S3; otherwise they are stored on local disk.
# Force one explicitly with STORAGE_DRIVER=s3 or STORAGE_DRIVER=local.
# STORAGE_DRIVER=s3
UPLOADS_DIR=./uploads

# S3 — fill these to store uploads in S3. AWS_REGION must be a REAL AWS region
# (e.g. us-east-1, eu-west-1, af-south-1) — not a made-up value.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Only for S3-compatible providers (Cloudflare R2, MinIO, ...) — then AWS_REGION
# can be any value the provider expects.
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# ---- Email (password-reset links) ----
# Two options; if neither is set, reset links are printed to the server
# console (visible via `pm2 logs sph-api`).
#
# RECOMMENDED: Brevo transactional HTTP API — delivers over https (port 443),
# so it works even where outbound SMTP is blocked (e.g. DigitalOcean droplets).
# Get a key at: Brevo > SMTP & API > API Keys > Generate a new API key.
BREVO_API_KEY=

# The "from" address — MUST be a VERIFIED sender in Brevo
# (Brevo > Senders, Domains & Dedicated IPs > Senders). Unverified senders are
# accepted by the API but never delivered.
MAIL_FROM_EMAIL=no-reply@swahilipothub.co.ke
MAIL_FROM_NAME=SwahiliPot IMS

# Optional SMTP fallback (only used if BREVO_API_KEY is empty).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SwahiliPot IMS <no-reply@swahilipothub.co.ke>

# ---- Chatbot (Q&A assistant) ----
# Choose ONE provider. If both are set, NVIDIA is used. If neither is set,
# the chat widget shows a "not available" message.
#
# Option A (recommended): NVIDIA API catalog — get a key at https://build.nvidia.com
NVIDIA_API_KEY=
# Optional: pick the primary model (defaults to a sensible NVIDIA model).
# Examples: meta/llama-3.3-70b-instruct, meta/llama-3.1-8b-instruct,
#           nvidia/llama-3.1-nemotron-70b-instruct, mistralai/mistral-7b-instruct-v0.3
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# Optional: only change for self-hosted NVIDIA NIM.
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
#
# Option B: OpenRouter — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
